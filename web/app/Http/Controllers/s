                ->leftJoin('users as assigner', 'assigner.usr_id', '=', 'service_appointment_schedules.svcas_assigned_by')
                ->where('service_appointment_schedules.svcas_active', 1)
                ->where('service_appointments.svca_approved_date', $approvedDate)
