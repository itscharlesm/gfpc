        let tt = null;

        function ensureTT() {
            if (!tt) {
                tt = document.createElement('div');

                tt.style.cssText = [
                    'position:fixed; background:#fff; border:0.5px solid #ccc;',
                    'border-radius:8px; padding:8px 12px; font-size:12px;',
