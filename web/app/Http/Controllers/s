                        ->where('service_appointments.svca_approved_time_from', '<', $approvedTimeTo)
                        ->where('service_appointments.svca_approved_time_to', '>', $approvedTimeFrom)
                        ->first();
                    $isBusy = (bool) $conflict;
                }

                $tech->is_rest_day = $isRestDay;
                $tech->is_busy = $isBusy;
                return $tech;
            });

